# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/

# JSONL truth + derived SQLite cache - committed to the dedicated `data`
# branch only (GRP-06), never to `main`. Ignored broadly here so a local
# `make ingest` run (without the `data`-branch worktree set up) can't get
# accidentally staged by a stray `git add -A` on `main` (PRD §5).
data/

# Rendered site output (`make build` / `make site`) - generated per run, never committed.
public/

# Local secrets - never committed (PRD §5). Real values live in CI masked vars.
.env
